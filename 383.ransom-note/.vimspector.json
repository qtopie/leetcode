{
  "adapters": {
    "delve-local": {
      "variables": {
        "port": "${unusedLocalPort}",
        "listenOn": "127.0.0.1",
        "dlvFlags": ""
      },
      "command": [
        "/home/qtopierw/workspace/go/bin/dlv",
        "dap",
        "--listen",
        "${listenOn}:${port}",
        "*${dlvFlags}"
      ],
      "tty": true,
      "port": "${port}"
    }
  },
  "configurations": {
    "Debug TestDebug": {
      "adapter": "delve-local",
      "filetypes": [ "go" ],
      "configuration": {
        "request": "launch",
        "mode": "test",
        "program": "${workspaceRoot}",
        "dlvCwd": "${workspaceRoot}",
        "args": [ "-test.run", "TestDebug" ]
      },
      "breakpoints": {
        "exception": {
          "unrecovered-panic": "",
          "runtime-fatal-throw": ""
        }
      }
    },
    "Debug Package": {
      "adapter": "delve-local",
      "filetypes": [ "go" ],
      "configuration": {
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceRoot}",
        "dlvCwd": "${workspaceRoot}"
      },
      "breakpoints": {
        "exception": {
          "unrecovered-panic": "",
          "runtime-fatal-throw": ""
        }
      }
    }
  }
}
